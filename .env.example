# Copy to ~/.local/share/jobdeck/.env (or export in your shell) and fill in.

# Jooble job search API key — free, request at https://jooble.org/api/about
JOOBLE_API_KEY=

# Anthropic API key for AI drafting and classification — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model used for drafting/classification (optional, this is the default)
ANTHROPIC_MODEL=claude-haiku-4-5
